      "query_recipes": [
        {"query_id": "evl2-dependencies", "family": "dependency_and_imports", "semantic_cues": ["model SDK, evaluation, judge, and scoring framework imports"], "query_patterns": [{"pattern_id":"evl2-dependency-import","regex":"\\b(import|from|require)\\b","flags":"i","anchor_kind":"evaluation_judge_configuration"}]},
        {"query_id": "evl2-direct", "family": "direct_calls_and_configuration", "semantic_cues": ["producer and judge model calls within one evaluation flow"], "query_patterns": [{"pattern_id":"evl2-direct-judge","regex":"\\b(judge|evaluate|score|chat|complete|generate)\\b","flags":"i","anchor_kind":"evaluation_judge_configuration"}]},
        {"query_id": "evl2-aliases", "family": "aliases_wrappers_and_helpers", "semantic_cues": ["model identifiers propagated to producer and judge helpers"], "query_patterns": [{"pattern_id":"evl2-alias","regex":"\\b(model|judge|provider|evaluator|scorer)\\b","flags":"i","anchor_kind":"evaluation_judge_configuration"}]},
        {"query_id": "evl2-registration", "family": "registrations_decorators_and_schemas", "semantic_cues": ["judge registration, scorer configuration, rubrics, and evaluator schemas"], "query_patterns": [{"pattern_id":"evl2-registration","regex":"\\b(judge|scorer|rubric|schema|evaluator)\\b","flags":"i","anchor_kind":"evaluation_judge_configuration"}]},
        {"query_id": "evl2-sinks", "family": "dataflow_sinks_persistence_and_logs", "semantic_cues": ["judge scores, verdicts, and evaluation result emission"], "query_patterns": [{"pattern_id":"evl2-sink","regex":"\\b(score|verdict|result|report|emit|log)\\b","flags":"i","anchor_kind":"evaluation_judge_configuration"}]},
        {"query_id": "evl2-boundaries", "family": "negative_boundaries_and_abstention", "semantic_cues": ["distinct judges, human review, deterministic oracles, tests, and unresolved dynamic model IDs"], "query_patterns": [{"pattern_id":"evl2-boundary","regex":"\\b(distinct|human|oracle|deterministic|test|example)\\b","flags":"i","anchor_kind":"evaluation_judge_configuration"}]}
      ]
    }
