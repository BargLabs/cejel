  "rules": [
    {
      "rule_id": "LLM-IOH-001",
      "anchor_kinds": ["executable_or_rendering_sink"],
      "canonical_locus": "Anchor the opportunity at the executable or rendering sink receiving observable model output.",
      "negative_boundary_policy": "A validated, escaped, or non-model-controlled sink remains a negative opportunity and must not be excluded.",
      "candidate_normalization": "Group producer, alias, helper, and sink signals into one candidate at the final side-effecting sink line.",
      "query_recipes": [
        {"query_id": "ioh-dependencies", "family": "dependency_and_imports", "semantic_cues": ["model SDK imports paired with execution, HTML, process, or evaluation APIs"], "query_patterns": [{"pattern_id":"ioh-dependency-import","regex":"\\b(import|from|require)\\b","flags":"i","anchor_kind":"executable_or_rendering_sink"}]},
        {"query_id": "ioh-direct", "family": "direct_calls_and_configuration", "semantic_cues": ["model response creation and direct dynamic or rendering sinks"], "query_patterns": [{"pattern_id":"ioh-direct-call","regex":"\\b(create|complete|chat|generate|render)\\b","flags":"i","anchor_kind":"executable_or_rendering_sink"}]},
        {"query_id": "ioh-aliases", "family": "aliases_wrappers_and_helpers", "semantic_cues": ["model-output aliases and local helpers forwarding values to sinks"], "query_patterns": [{"pattern_id":"ioh-alias","regex":"\\b(output|response|result|message|payload)\\b","flags":"i","anchor_kind":"executable_or_rendering_sink"}]},
        {"query_id": "ioh-registration", "family": "registrations_decorators_and_schemas", "semantic_cues": ["registered tools or handlers whose parameters reach executable sinks"], "query_patterns": [{"pattern_id":"ioh-registration","regex":"\\b(tool|handler|register|decorator|schema)\\b","flags":"i","anchor_kind":"executable_or_rendering_sink"}]},
        {"query_id": "ioh-sinks", "family": "dataflow_sinks_persistence_and_logs", "semantic_cues": ["dynamic evaluation, process execution, raw HTML, or equivalent side effects"], "query_patterns": [{"pattern_id":"ioh-sink","regex":"\\b(eval|exec|spawn|system|render|html)\\b","flags":"i","anchor_kind":"executable_or_rendering_sink"}]},
        {"query_id": "ioh-boundaries", "family": "negative_boundaries_and_abstention", "semantic_cues": ["escaping, strict validation, constant values, tests, examples, and unsupported lineage"], "query_patterns": [{"pattern_id":"ioh-boundary","regex":"\\b(escape|sanitize|validate|test|example|mock)\\b","flags":"i","anchor_kind":"executable_or_rendering_sink"}]}
      ]
    },
    {
      "rule_id": "LLM-VAL-001",
      "anchor_kinds": ["action_dispatch_sink"],
      "canonical_locus": "Anchor the opportunity at the action dispatch or side-effect call consuming model-derived structured data.",
      "negative_boundary_policy": "A closed-schema or literal-constrained dispatch remains a negative opportunity and must not be excluded.",
      "candidate_normalization": "Group parsing, schema, alias, helper, and dispatcher signals into one candidate at the final action sink.",
      "query_recipes": [
        {"query_id": "val-dependencies", "family": "dependency_and_imports", "semantic_cues": ["model SDK, schema library, tool framework, and action API imports"], "query_patterns": [{"pattern_id":"val-dependency-import","regex":"\\b(import|from|require)\\b","flags":"i","anchor_kind":"action_dispatch_sink"}]},
        {"query_id": "val-direct", "family": "direct_calls_and_configuration", "semantic_cues": ["model output parsing followed by action or dispatch calls"], "query_patterns": [{"pattern_id":"val-direct-dispatch","regex":"\\b(dispatch|action|execute|apply|send)\\b","flags":"i","anchor_kind":"action_dispatch_sink"}]},
        {"query_id": "val-aliases", "family": "aliases_wrappers_and_helpers", "semantic_cues": ["parsed model fields propagated through local aliases or helpers"], "query_patterns": [{"pattern_id":"val-alias","regex":"\\b(parsed|output|response|args|payload)\\b","flags":"i","anchor_kind":"action_dispatch_sink"}]},
        {"query_id": "val-registration", "family": "registrations_decorators_and_schemas", "semantic_cues": ["tool schemas, decorators, argument models, and registered callbacks"], "query_patterns": [{"pattern_id":"val-registration","regex":"\\b(tool|schema|register|decorator|callback)\\b","flags":"i","anchor_kind":"action_dispatch_sink"}]},
        {"query_id": "val-sinks", "family": "dataflow_sinks_persistence_and_logs", "semantic_cues": ["deployment, mutation, process, file, network, or equivalent action sinks"], "query_patterns": [{"pattern_id":"val-sink","regex":"\\b(write|delete|deploy|request|send|execute)\\b","flags":"i","anchor_kind":"action_dispatch_sink"}]},
        {"query_id": "val-boundaries", "family": "negative_boundaries_and_abstention", "semantic_cues": ["closed enums, strict schemas, literal constraints, and unsupported dispatchers"], "query_patterns": [{"pattern_id":"val-boundary","regex":"\\b(enum|literal|strict|validate|allowlist|deny)\\b","flags":"i","anchor_kind":"action_dispatch_sink"}]}
      ]
    },
    {
      "rule_id": "LLM-AGY-001",
      "anchor_kinds": ["privileged_side_effect"],
      "canonical_locus": "Anchor the opportunity at each privileged side effect reachable from one model-facing registered tool.",
      "negative_boundary_policy": "A preceding fail-closed human approval or policy gate remains a negative opportunity and must not be excluded.",
      "candidate_normalization": "Create one candidate per privileged side effect, retaining registration and approval signals as supporting hits.",
      "query_recipes": [
        {"query_id": "agy1-dependencies", "family": "dependency_and_imports", "semantic_cues": ["agent or tool SDK imports paired with privileged capability imports"], "query_patterns": [{"pattern_id":"agy1-dependency-import","regex":"\\b(import|from|require)\\b","flags":"i","anchor_kind":"privileged_side_effect"}]},
        {"query_id": "agy1-direct", "family": "direct_calls_and_configuration", "semantic_cues": ["model-facing tools that directly perform privileged side effects"], "query_patterns": [{"pattern_id":"agy1-direct-tool","regex":"\\b(tool|agent|action|command)\\b","flags":"i","anchor_kind":"privileged_side_effect"}]},
        {"query_id": "agy1-aliases", "family": "aliases_wrappers_and_helpers", "semantic_cues": ["tool parameters forwarded through local helpers into privileged operations"], "query_patterns": [{"pattern_id":"agy1-alias","regex":"\\b(args|params|input|payload|request)\\b","flags":"i","anchor_kind":"privileged_side_effect"}]},
        {"query_id": "agy1-registration", "family": "registrations_decorators_and_schemas", "semantic_cues": ["tool registration, decorators, callbacks, and exposed tool collections"], "query_patterns": [{"pattern_id":"agy1-registration","regex":"\\b(tool|register|decorator|callback|expose)\\b","flags":"i","anchor_kind":"privileged_side_effect"}]},
        {"query_id": "agy1-sinks", "family": "dataflow_sinks_persistence_and_logs", "semantic_cues": ["file mutation, shell execution, network mutation, database writes, and equivalent effects"], "query_patterns": [{"pattern_id":"agy1-sink","regex":"\\b(write|delete|exec|spawn|request|insert|update)\\b","flags":"i","anchor_kind":"privileged_side_effect"}]},
        {"query_id": "agy1-boundaries", "family": "negative_boundaries_and_abstention", "semantic_cues": ["human approval, policy denial, dry-run, read-only tools, tests, and examples"], "query_patterns": [{"pattern_id":"agy1-boundary","regex":"\\b(approve|approval|deny|dry.run|read.only|test|example)\\b","flags":"i","anchor_kind":"privileged_side_effect"}]}
      ]
    },
    {
      "rule_id": "LLM-AGY-002",
      "anchor_kinds": ["model_call_in_control_loop"],
      "canonical_locus": "Anchor the opportunity at the model call executed within the controlling iterative loop.",
      "negative_boundary_policy": "A statically bounded loop, deadline, cancellation, or finite iteration guard remains a negative opportunity.",
      "candidate_normalization": "Group loop, model-call, retry, deadline, and termination signals at the model-call line inside the loop.",
      "query_recipes": [
        {"query_id": "agy2-dependencies", "family": "dependency_and_imports", "semantic_cues": ["model SDK and agent-loop framework imports"], "query_patterns": [{"pattern_id":"agy2-dependency-import","regex":"\\b(import|from|require)\\b","flags":"i","anchor_kind":"model_call_in_control_loop"}]},
        {"query_id": "agy2-direct", "family": "direct_calls_and_configuration", "semantic_cues": ["model calls lexically contained in loops or recursive controllers"], "query_patterns": [{"pattern_id":"agy2-direct-loop","regex":"\\b(for|while|retry|loop|agent|chat|complete|generate)\\b","flags":"i","anchor_kind":"model_call_in_control_loop"}]},
        {"query_id": "agy2-aliases", "family": "aliases_wrappers_and_helpers", "semantic_cues": ["model-call wrappers invoked from loops and recursive helpers"], "query_patterns": [{"pattern_id":"agy2-alias","regex":"\\b(response|output|result|message|next)\\b","flags":"i","anchor_kind":"model_call_in_control_loop"}]},
        {"query_id": "agy2-registration", "family": "registrations_decorators_and_schemas", "semantic_cues": ["agent runners, retry policies, graph cycles, and loop configuration"], "query_patterns": [{"pattern_id":"agy2-registration","regex":"\\b(agent|runner|retry|graph|cycle|loop)\\b","flags":"i","anchor_kind":"model_call_in_control_loop"}]},
        {"query_id": "agy2-sinks", "family": "dataflow_sinks_persistence_and_logs", "semantic_cues": ["iteration state, continuation decisions, and repeated model invocation sites"], "query_patterns": [{"pattern_id":"agy2-sink","regex":"\\b(iteration|state|continue|complete|generate|invoke)\\b","flags":"i","anchor_kind":"model_call_in_control_loop"}]},
        {"query_id": "agy2-boundaries", "family": "negative_boundaries_and_abstention", "semantic_cues": ["finite ranges, counters, deadlines, cancellation, breaks, and unsupported dynamic bounds"], "query_patterns": [{"pattern_id":"agy2-boundary","regex":"\\b(range|count|limit|deadline|cancel|break|timeout)\\b","flags":"i","anchor_kind":"model_call_in_control_loop"}]}
      ]
    },
    {
      "rule_id": "LLM-DAT-001",
      "anchor_kinds": ["model_request_secret_argument"],
      "canonical_locus": "Anchor the opportunity at the model request argument containing sensitive environment or credential material.",
      "negative_boundary_policy": "Credentials used only for provider authentication remain negative opportunities and must not be excluded.",
      "candidate_normalization": "Group secret sources, aliases, templates, and model calls at the request argument that carries the sensitive value.",
      "query_recipes": [
        {"query_id": "dat-dependencies", "family": "dependency_and_imports", "semantic_cues": ["model SDK and environment, secret-manager, or credential imports"], "query_patterns": [{"pattern_id":"dat-dependency-import","regex":"\\b(import|from|require)\\b","flags":"i","anchor_kind":"model_request_secret_argument"}]},
        {"query_id": "dat-direct", "family": "direct_calls_and_configuration", "semantic_cues": ["sensitive environment reads embedded in model request arguments"], "query_patterns": [{"pattern_id":"dat-direct-env","regex":"\\b(env|secret|token|password|credential)\\b","flags":"i","anchor_kind":"model_request_secret_argument"}]},
        {"query_id": "dat-aliases", "family": "aliases_wrappers_and_helpers", "semantic_cues": ["secret aliases and templates propagated into model requests"], "query_patterns": [{"pattern_id":"dat-alias","regex":"\\b(secret|token|credential|template|prompt)\\b","flags":"i","anchor_kind":"model_request_secret_argument"}]},
        {"query_id": "dat-registration", "family": "registrations_decorators_and_schemas", "semantic_cues": ["prompt templates, request schemas, tool parameters, and configuration bindings"], "query_patterns": [{"pattern_id":"dat-registration","regex":"\\b(schema|config|prompt|template|parameter|tool)\\b","flags":"i","anchor_kind":"model_request_secret_argument"}]},
        {"query_id": "dat-sinks", "family": "dataflow_sinks_persistence_and_logs", "semantic_cues": ["model request payloads and prompt or message construction"], "query_patterns": [{"pattern_id":"dat-sink","regex":"\\b(messages?|prompt|request|chat|complete|generate)\\b","flags":"i","anchor_kind":"model_request_secret_argument"}]},
        {"query_id": "dat-boundaries", "family": "negative_boundaries_and_abstention", "semantic_cues": ["provider API-key constructors, redaction, allowlists, tests, examples, and unsupported secret names"], "query_patterns": [{"pattern_id":"dat-boundary","regex":"\\b(api.key|redact|allowlist|test|example|mock)\\b","flags":"i","anchor_kind":"model_request_secret_argument"}]}
      ]
    },
    {
      "rule_id": "LLM-PRV-001",
      "anchor_kinds": ["evaluation_result_emission"],
      "canonical_locus": "Anchor the opportunity at the persisted or emitted evaluation result whose lineage should be reproducible.",
      "negative_boundary_policy": "A result carrying complete model, dataset, prompt, configuration, and run lineage remains a negative opportunity.",
      "candidate_normalization": "Group evaluation inputs, scoring, lineage fields, and persistence into one candidate at result emission.",
      "query_recipes": [
        {"query_id": "prv-dependencies", "family": "dependency_and_imports", "semantic_cues": ["model SDK, evaluation framework, dataset, and result-storage imports"], "query_patterns": [{"pattern_id":"prv-dependency-import","regex":"\\b(import|from|require)\\b","flags":"i","anchor_kind":"evaluation_result_emission"}]},
        {"query_id": "prv-direct", "family": "direct_calls_and_configuration", "semantic_cues": ["evaluation execution followed by local metric or report construction"], "query_patterns": [{"pattern_id":"prv-direct-eval","regex":"\\b(eval|evaluate|score|metric|report)\\b","flags":"i","anchor_kind":"evaluation_result_emission"}]},
        {"query_id": "prv-aliases", "family": "aliases_wrappers_and_helpers", "semantic_cues": ["model, prompt, dataset, and configuration lineage propagated through helpers"], "query_patterns": [{"pattern_id":"prv-alias","regex":"\\b(model|prompt|dataset|config|lineage)\\b","flags":"i","anchor_kind":"evaluation_result_emission"}]},
        {"query_id": "prv-registration", "family": "registrations_decorators_and_schemas", "semantic_cues": ["evaluation cases, experiment configuration, and result schemas"], "query_patterns": [{"pattern_id":"prv-registration","regex":"\\b(case|experiment|schema|config|evaluator)\\b","flags":"i","anchor_kind":"evaluation_result_emission"}]},
        {"query_id": "prv-sinks", "family": "dataflow_sinks_persistence_and_logs", "semantic_cues": ["evaluation result persistence, export, logging, or publication"], "query_patterns": [{"pattern_id":"prv-sink","regex":"\\b(save|write|export|log|publish|report)\\b","flags":"i","anchor_kind":"evaluation_result_emission"}]},
        {"query_id": "prv-boundaries", "family": "negative_boundaries_and_abstention", "semantic_cues": ["complete lineage keys, externally governed provenance, tests, and unsupported result formats"], "query_patterns": [{"pattern_id":"prv-boundary","regex":"\\b(lineage|provenance|test|example|mock|external)\\b","flags":"i","anchor_kind":"evaluation_result_emission"}]}
      ]
    },
    {
      "rule_id": "LLM-EVL-001",
      "anchor_kinds": ["evaluation_metric_emission"],
      "canonical_locus": "Anchor the opportunity at the emitted aggregate evaluation metric whose denominator should be explicit.",
      "negative_boundary_policy": "A metric with an explicit eligible-case denominator and exclusions remains a negative opportunity.",
      "candidate_normalization": "Group case iteration, eligibility, numerator, denominator, and emission at the aggregate metric output.",
      "query_recipes": [
        {"query_id": "evl1-dependencies", "family": "dependency_and_imports", "semantic_cues": ["model SDK, evaluation, metric, and dataset imports"], "query_patterns": [{"pattern_id":"evl1-dependency-import","regex":"\\b(import|from|require)\\b","flags":"i","anchor_kind":"evaluation_metric_emission"}]},
        {"query_id": "evl1-direct", "family": "direct_calls_and_configuration", "semantic_cues": ["case iteration and locally computed aggregate metrics"], "query_patterns": [{"pattern_id":"evl1-direct-metric","regex":"\\b(metric|accuracy|score|rate|average|mean)\\b","flags":"i","anchor_kind":"evaluation_metric_emission"}]},
        {"query_id": "evl1-aliases", "family": "aliases_wrappers_and_helpers", "semantic_cues": ["eligible-case and denominator aliases propagated into metric calculation"], "query_patterns": [{"pattern_id":"evl1-alias","regex":"\\b(eligible|denominator|numerator|count|total)\\b","flags":"i","anchor_kind":"evaluation_metric_emission"}]},
        {"query_id": "evl1-registration", "family": "registrations_decorators_and_schemas", "semantic_cues": ["evaluation case definitions, filters, scorers, and metric schemas"], "query_patterns": [{"pattern_id":"evl1-registration","regex":"\\b(case|filter|scorer|schema|metric)\\b","flags":"i","anchor_kind":"evaluation_metric_emission"}]},
        {"query_id": "evl1-sinks", "family": "dataflow_sinks_persistence_and_logs", "semantic_cues": ["accuracy, rate, or score persistence, logging, and export"], "query_patterns": [{"pattern_id":"evl1-sink","regex":"\\b(accuracy|rate|score|save|log|export)\\b","flags":"i","anchor_kind":"evaluation_metric_emission"}]},
        {"query_id": "evl1-boundaries", "family": "negative_boundaries_and_abstention", "semantic_cues": ["explicit eligible denominators, exclusion counts, tests, and unsupported aggregation"], "query_patterns": [{"pattern_id":"evl1-boundary","regex":"\\b(eligible|denominator|exclude|test|example|mock)\\b","flags":"i","anchor_kind":"evaluation_metric_emission"}]}
      ]
    },
    {
      "rule_id": "LLM-EVL-002",
      "anchor_kinds": ["evaluation_judge_configuration"],
      "canonical_locus": "Anchor the opportunity at the judge configuration used to score outputs from the evaluated model.",
      "negative_boundary_policy": "A distinct judge, independent human rubric, or deterministic oracle remains a negative opportunity.",
