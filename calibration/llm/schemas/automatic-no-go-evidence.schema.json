{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cejel.dev/schemas/llm/automatic-no-go-evidence-v1.json",
  "title": "Cejel Free LLM automatic no-go evidence record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "protocol_id", "check_id", "observed_at", "detector_binding", "artifacts"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "protocol_id": {"const": "cejel-llm-calibration-v1"},
    "check_id": {"enum": ["free_core_unchanged_without_pack", "offline_scan_path_verified", "all_findings_have_resolvable_evidence", "prohibited_public_claims_absent", "untouched_blinding_preserved"]},
    "observed_at": {"type": "string", "format": "date-time"},
    "detector_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["build_sha256", "source_commit"],
      "properties": {
        "build_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "source_commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"}
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "name", "media_type", "encoding", "content", "sha256"],
        "properties": {
          "kind": {"enum": ["test_run", "network_isolation_audit", "derived_finding_path_audit", "claim_audit", "chronology_audit"]},
          "name": {"type": "string", "minLength": 3},
          "media_type": {"const": "application/json"},
          "encoding": {"const": "utf8"},
          "content": {"type": "string", "minLength": 2},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    }
  }
}
