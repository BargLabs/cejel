{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cejel.dev/schemas/llm/detector-freeze-v1.json",
  "title": "Cejel Free LLM detector freeze",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "protocol_id", "status", "frozen_at", "detector", "execution", "rule_ids", "support_matrix", "golden_correction_ledger", "golden_execution_evidence", "untouched_results_seen_before_freeze", "record_sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "protocol_id": {"const": "cejel-llm-calibration-v1"},
    "status": {"const": "detector_frozen_before_untouched"},
    "frozen_at": {"type": "string", "format": "date-time"},
    "detector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["git_commit", "build_sha256", "artifact_name", "runtime"],
      "properties": {
        "git_commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
        "build_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "artifact_name": {"type": "string", "minLength": 1},
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "platform", "architecture"],
          "properties": {
            "name": {"type": "string", "minLength": 1},
            "version": {"type": "string", "minLength": 1},
            "platform": {"type": "string", "minLength": 1},
            "architecture": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command_template", "network_isolation"],
      "properties": {
        "command_template": {"type": "array", "minItems": 8, "items": {"type": "string"}},
        "network_isolation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "argv_prefix", "evidence_reference", "explicitly_confirmed"],
          "properties": {
            "mode": {"type": "string", "minLength": 3},
            "argv_prefix": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
            "evidence_reference": {"type": "string", "minLength": 8},
            "explicitly_confirmed": {"const": true}
          }
        }
      }
    },
    "rule_ids": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {"pattern": "^LLM-[A-Z]{3}-[0-9]{3}$"}
    },
    "support_matrix": {"type": "object"},
    "golden_correction_ledger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "golden_manifest_sha256", "status", "entries", "open_corrections", "frozen_at"],
      "properties": {
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "golden_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "status": {"const": "frozen"},
        "entries": {"type": "integer", "minimum": 0},
        "open_corrections": {"const": 0},
        "frozen_at": {"type": "string", "format": "date-time"}
      }
    },
    "golden_execution_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "executions", "findings", "golden_manifest_sha256", "detector_build_sha256"],
      "properties": {
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "executions": {"type": "integer", "minimum": 1},
        "findings": {"type": "integer", "minimum": 0},
        "golden_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "detector_build_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "untouched_results_seen_before_freeze": {"const": false},
    "record_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
