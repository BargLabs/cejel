{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cejel.dev/schemas/llm/golden-execution-evidence-v1.json",
  "title": "Cejel Free LLM golden execution evidence index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "protocol_id", "cohort", "golden_manifest_sha256", "detector_build_sha256", "executions"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "protocol_id": {"const": "cejel-llm-calibration-v1"},
    "cohort": {"const": "golden"},
    "golden_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "detector_build_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "executions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["repository_id", "receipt", "llm_report"],
        "properties": {
          "repository_id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
          "receipt": {"$ref": "#/$defs/bound_document"},
          "llm_report": {"$ref": "#/$defs/bound_document"}
        }
      }
    }
  },
  "$defs": {
    "bound_document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document_sha256", "document"],
      "properties": {
        "document_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "document": {"type": "object"}
      }
    }
  }
}
