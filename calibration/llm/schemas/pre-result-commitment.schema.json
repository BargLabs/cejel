{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cejel.dev/schemas/llm/pre-result-commitment-v1.json",
  "title": "Cejel Free LLM externally committed pre-result bindings",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "protocol_id", "status", "created_at", "detector_results_seen_before_commitment", "golden_manifest_sha256", "untouched_manifest_sha256", "opportunity_manifest_sha256", "blind_label_bindings"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "protocol_id": {"const": "cejel-llm-calibration-v1"},
    "status": {"const": "frozen_pre_result"},
    "created_at": {"type": "string", "format": "date-time"},
    "detector_results_seen_before_commitment": {"const": false},
    "golden_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "untouched_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "opportunity_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "blind_label_bindings": {
      "type": "array", "minItems": 2,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["label_id", "document_sha256", "role"],
        "properties": {
          "label_id": {"type": "string", "pattern": "^llm-label-[a-z0-9-]{8,80}$"},
          "document_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "role": {"enum": ["primary_labeler", "independent_reviewer", "adjudicator"]}
        }
      }
    }
  }
}
