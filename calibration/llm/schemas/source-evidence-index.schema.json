{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cejel.dev/schemas/llm/source-evidence-index-v1.json",
  "title": "Cejel Free LLM pinned source-evidence index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "protocol_id", "status", "hash_contract", "cohort_bindings", "files", "index_sha256", "attestation"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "1.0.0"},
    "protocol_id": {"const": "cejel-llm-calibration-v1"},
    "status": {"const": "frozen_before_detector_results"},
    "hash_contract": {"const": "rfc8785-sha256-v1; index excludes index_sha256 and attestation; file content_sha256 hashes decoded whole-file bytes"},
    "cohort_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["golden_manifest_sha256", "untouched_manifest_sha256"],
      "properties": {
        "golden_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "untouched_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cohort", "repository_id", "commit_sha", "git_tree_sha", "path", "blob_sha1", "content_base64", "content_sha256", "tree_proof"],
        "properties": {
          "cohort": {"enum": ["golden", "untouched"]},
          "repository_id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
          "commit_sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
          "git_tree_sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
          "path": {"type": "string", "minLength": 1},
          "blob_sha1": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
          "content_base64": {"type": "string", "minLength": 1},
          "content_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "tree_proof": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["tree_sha1", "tree_base64"],
              "properties": {
                "tree_sha1": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
                "tree_base64": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    },
    "index_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "reference"],
      "properties": {
        "method": {"type": "string", "minLength": 3},
        "reference": {"type": "string", "minLength": 8}
      }
    }
  }
}
