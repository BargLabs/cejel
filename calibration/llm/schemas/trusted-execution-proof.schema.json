{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cejel.dev/schemas/llm/trusted-execution-proof-v1.json",
  "title": "Cejel Free LLM trusted GitHub execution proof",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "protocol_id", "provider", "repository", "commitment", "runs"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "protocol_id": {"const": "cejel-llm-calibration-v1"},
    "provider": {"const": "github_actions_public_v1"},
    "repository": {"const": "BargLabs/cejel"},
    "commitment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["git_commit", "document_sha256", "comment_id", "comment_api_url", "created_at"],
      "properties": {
        "git_commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
        "document_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "comment_id": {"type": "integer", "minimum": 1},
        "comment_api_url": {"type": "string", "pattern": "^https://api.github.com/repos/BargLabs/cejel/issues/comments/[0-9]+$"},
        "created_at": {"type": "string", "format": "date-time"}
      }
    },
    "runs": {
      "type": "array", "minItems": 2, "maxItems": 2,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["cohort", "run_id", "run_api_url", "head_sha", "workflow_sha256", "artifact"],
        "properties": {
          "cohort": {"enum": ["golden", "untouched"]},
          "run_id": {"type": "integer", "minimum": 1},
          "run_api_url": {"type": "string"},
          "head_sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
          "workflow_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "artifact": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "api_url", "archive_sha256", "evidence_bundle_sha256"],
            "properties": {
              "id": {"type": "integer", "minimum": 1},
              "api_url": {"type": "string"},
              "archive_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
              "evidence_bundle_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
            }
          }
        }
      }
    }
  }
}
