import { writeFileSync } from 'node:fs';
import OpenAI from 'openai';
const openai = new OpenAI();

const response = await openai.responses.create({ model: 'gpt-4.1-2025-04-14', input: candidate });
const eligible = results.filter((result) => result.status === 'ok');
const accuracy = eligible.filter((result) => result.output === response.output_text).length / eligible.length;
const n = eligible.length;

writeFileSync(
  'evaluation.json',
  JSON.stringify({ accuracy, n, modelId, promptDigest }),
);
